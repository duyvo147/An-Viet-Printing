{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with roles for RBAC",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff"] },
        "isApproved": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "isApproved"]
    },
    "Order": {
      "title": "Order",
      "description": "Printing order details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "printingInfo": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "subTotal": { "type": "number" },
        "vatRate": { "type": "number" },
        "vatAmount": { "type": "number" },
        "totalAmount": { "type": "number" },
        "paidAmount": { "type": "number" },
        "debtAmount": { "type": "number" },
        "vatInvoiceCode": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "partial", "paid"] },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "totalAmount", "status", "paymentStatus", "createdBy"]
    },
    "ActivityLog": {
      "title": "ActivityLog",
      "description": "History of user actions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "action", "timestamp"]
    },
    "SupplierOrder": {
      "title": "SupplierOrder",
      "description": "Purchase order for materials or outsourcing",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "supplierName": { "type": "string" },
        "supplierPhone": { "type": "string" },
        "supplierAddress": { "type": "string" },
        "supplierTaxId": { "type": "string" },
        "bankName": { "type": "string" },
        "bankAccountName": { "type": "string" },
        "bankAccountNumber": { "type": "string" },
        "materialType": { "type": "string", "enum": ["paper", "ink", "outsourcing", "other"] },
        "description": { "type": "string" },
        "vatInvoiceCode": { "type": "string" },
        "totalAmount": { "type": "number" },
        "paidAmount": { "type": "number" },
        "debtAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "received", "cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "partial", "paid"] },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["supplierName", "totalAmount", "status", "paymentStatus", "createdBy"]
    },
    "PaperType": {
      "title": "PaperType",
      "description": "Configurable paper types and prices",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "pricePerA4": { "type": "number" }
      },
      "required": ["id", "name", "pricePerA4"]
    },
    "PostProcessingType": {
      "title": "PostProcessingType",
      "description": "Configurable post-processing options",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "pricePerM2": { "type": "number" },
        "pricePerUnit": { "type": "number" }
      },
      "required": ["id", "name"]
    },
    "PrintConfig": {
      "title": "PrintConfig",
      "description": "General printing price configuration",
      "type": "object",
      "properties": {
        "basePrice1Side": { "type": "number" },
        "basePrice2Sides": { "type": "number" },
        "tier1Threshold": { "type": "number" },
        "tier1Discount": { "type": "number" },
        "tier2Threshold": { "type": "number" },
        "tier2Discount": { "type": "number" },
        "tier3Threshold": { "type": "number" },
        "tier3Discount": { "type": "number" }
      },
      "required": ["basePrice1Side", "basePrice2Sides"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Printing order documents"
    },
    "/activity_logs/{logId}": {
      "schema": "ActivityLog",
      "description": "Activity log documents"
    },
    "/supplier_orders/{orderId}": {
      "schema": "SupplierOrder",
      "description": "Supplier purchase order documents"
    },
    "/settings_paper/{paperId}": {
      "schema": "PaperType",
      "description": "Paper type settings"
    },
    "/settings_processing/{procId}": {
      "schema": "PostProcessingType",
      "description": "Post-processing settings"
    },
    "/settings_print_config/main": {
      "schema": "PrintConfig",
      "description": "Main printing configuration"
    }
  }
}
